          },
          {
            "group": "Portfolio",
            "pages": [
              "api-reference/portfolio/get",
              "api-reference/portfolio/add",
              "api-reference/portfolio/remove"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Energy contract marketplace with advanced filtering by energy type, price, quantity, location, and date range",
    "Personal portfolio management with metrics (total capacity, total cost, average price per MWh)",
    "Interactive price trend charts showing average prices by energy type over time",
    "Side-by-side contract comparison (up to 3 contracts at once)",
    "Supabase-backed authentication with JWT token management",
    "Dark/light theme toggle with persistent state via Zustand",
    "Full CRUD operations for energy contracts via REST API",
    "Automatic OpenAPI documentation via FastAPI at /docs"
  ],
  "publicApiSurface": [
    "POST /api/login",
    "GET /api/contracts",
    "GET /api/contracts/{contract_id}",
    "POST /api/contracts",
    "PUT /api/contracts/{contract_id}",
    "DELETE /api/contracts/{contract_id}",
    "POST /api/contracts/{contract_id}/sell",
    "GET /api/contracts/trends",
    "GET /api/portfolio",
    "POST /api/portfolio/{contract_id}",
    "DELETE /api/portfolio/{contract_id}"
  ]
}
