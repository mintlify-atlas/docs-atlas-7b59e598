{
  "projectType": "saas",
  "projectName": "Energy Contracts Dashboard",
  "projectDescription": "A full-stack energy trading platform where users can browse, filter, and manage energy contracts across solar, wind, nuclear, and other energy types, with portfolio tracking and price trend analytics.",
  "theme": "linden",
  "primaryColor": "#16a34a",
  "lightColor": "#bbf7d0",
  "darkColor": "#14532d",
