            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Setup",
            "pages": ["setup/prerequisites", "setup/database", "setup/environment"]
          },
          {
            "group": "Core Features",
            "pages": ["features/marketplace", "features/portfolio", "features/price-trends", "features/contract-comparison"]
          },
          {
            "group": "Architecture",
            "pages": ["architecture/overview", "architecture/frontend", "architecture/backend", "architecture/authentication"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Authentication",
            "pages": ["api-reference/auth/login"]
          },
          {
            "group": "Contracts",
            "pages": [
              "api-reference/contracts/list",
              "api-reference/contracts/get",
              "api-reference/contracts/create",
              "api-reference/contracts/update",
              "api-reference/contracts/delete",
